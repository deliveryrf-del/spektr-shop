generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id             Int       @id @default(autoincrement())
  title          String
  slug           String    @unique
  products       Product[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  metaTitle      String?
  metaDescription String?
}

model Product {
  id             Int       @id @default(autoincrement())
  title          String
  sku            String    @unique
  price          Int
  stock          Int       @default(0)
  images         String[]  @default([])
  excerpt        String?
  content        String?
  category       Category? @relation(fields: [categoryId], references: [id])
  categoryId     Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  metaTitle      String?
  metaDescription String?
  slug           String?   @unique
}

model Order {
  id         Int       @id @default(autoincrement())
  items      Json
  total      Int
  customer   String
  email      String
  phone      String
  address    String?
  delivery   Json?
  paymentId  String?
  status     String    @default("new")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}
